# ==============================================================================
# Archi3D — Environment Variables Template
# ==============================================================================
# HOW TO USE:
#   1. Copy this file to .env  →  cp .env.example .env
#   2. Fill in your actual values in .env
#   3. NEVER commit your .env file to Git
#
# The .env file is loaded automatically by archi3d/settings.py using
# django-environ. All variables here are read with type-safe parsing.
# ==============================================================================

# ── Django Core ───────────────────────────────────────────────────────────────

# Secret key for Django (cryptographic signing, sessions, CSRF)
# Generate a new one with:  python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here

# Debug mode — set to False in production ALWAYS
DEBUG=True

# Comma-separated list of allowed hostnames (used in production)
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ──────────────────────────────────────────────────────────────────

# SQLite (default for development — no setup required)
DATABASE_URL=sqlite:///db.sqlite3

# PostgreSQL example (for production):
# DATABASE_URL=postgres://user:password@localhost:5432/archi3d

# ── Ollama (Local LLM — Phase 2) ──────────────────────────────────────────────

# URL where your local Ollama server is running
# Default: http://localhost:11434 (standard Ollama install)
OLLAMA_HOST=http://localhost:11434

# Model to use for design parsing and explanation
# Must be pulled first:  ollama pull llama3.2
OLLAMA_MODEL=llama3.2

# ── Paths ─────────────────────────────────────────────────────────────────────

# Directory where generated 3D models (GLB) and Hypar JSON are saved
# Relative to the backend/ directory
OUTPUTS_DIR=outputs

# Directory containing bylaw JSON files
BYLAWS_DIR=bylaws

# Directory containing the BM25 knowledge base JSON
KNOWLEDGE_DIR=knowledge

# ── API Settings ──────────────────────────────────────────────────────────────

# Maximum number of BM25 results to retrieve per query
RAG_TOP_K=5

# CORS — Origins allowed to call this API (for the React frontend)
# Example: http://localhost:5173 (Vite default port)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
